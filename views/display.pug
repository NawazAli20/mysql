doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Document
        link(rel="stylesheet", href="./styles.css")
    body
        h1 Student information
        if students.length==0
            p No student information is available 
        else 
            table
                tr
                    th ID
                    th Name 
                    th Department
                    th Total Credit
                each student in students
                    tr
                        td= student.id 
                        td= student.name 
                        td= student.dept_name 
                        td= student.tot_credit